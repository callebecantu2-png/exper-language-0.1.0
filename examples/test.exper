struct Pessoa {

    nome = "Sem nome"
    idade = 0
    ativo = True

}

fn soma(a, b=10) {
    return a + b
}

pessoa = Pessoa()

pessoa.nome = "Callebe"
pessoa.idade = 18

numero = 42
decimal = 3.14

hexa = 0xFF
binario = 0b101010

resultado = soma(numero, 8)

if (pessoa.idade >= 18 and pessoa.ativo) {

    console.log("Olá {pessoa.nome}")
    console.log("Resultado: {resultado}")

} 
else {

    console.log("Menor de idade")

}

