console.clear()

console.log("=== MINI RPG ===")

nome = console.input("Digite seu nome: ")

vida = 100
ataque = 15

vida_monstro = 80
ataque_monstro = 10

inventario = ["Poção"]

while (vida > 0 and vida_monstro > 0) {

    console.log("")
    console.log("=== STATUS ===")
    console.log("Jogador: {nome}")
    console.log("Sua vida: {vida}")
    console.log("Vida do monstro: {vida_monstro}")

    console.log("")
    console.log("1 - Atacar")
    console.log("2 - Curar")
    console.log("3 - Inventário")
    console.log("4 - Fugir")

    escolha = console.input("> ")

    if (escolha == "1") {

        vida_monstro = vida_monstro - ataque

        console.log("Você atacou!")
        console.log("Dano causado: {ataque}")

        if (vida_monstro <= 0) {
            break
        }

        vida = vida - ataque_monstro

        console.log("O monstro atacou!")
        console.log("Dano recebido: {ataque_monstro}")
    }

    elif (escolha == "2") {

        vida = vida + 20

        if (vida > 100) {
            vida = 100
        }

        console.log("Você se curou!")
    }

    elif (escolha == "3") {

        console.log("Inventário:")
        
        for item in inventario {
            console.log(item)
        }
    }

    elif (escolha == "4") {

        console.log("Você fugiu!")
        break
    }

    else {

        console.log("Opção inválida")
    }
}

console.log("")

if (vida_monstro <= 0) {
    console.log("VOCÊ VENCEU!")
}
elif (vida <= 0) {
    console.log("VOCÊ PERDEU!")
}
else {
    console.log("Fim da aventura.")
}