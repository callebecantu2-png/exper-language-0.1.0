{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Exper",
	"scopeName": "source.exper",

	"patterns": [
		{ "include": "#comments" },
		{ "include": "#strings" },
		{ "include": "#interpolation" },
		{ "include": "#keywords" },
		{ "include": "#booleans" },
		{ "include": "#numbers" },
		{ "include": "#operators" },
		{ "include": "#builtins" },
		{ "include": "#functions" },
		{ "include": "#properties" },
		{ "include": "#variables" }
	],

	"repository": {

		"comments": {
			"patterns": [
				{
					"name": "comment.line.double-slash.exper",
					"match": "//.*$"
				}
			]
		},

		"strings": {
			"patterns": [
				{
					"name": "string.quoted.double.exper",
					"begin": "\"",
					"end": "\"",
					"patterns": [
						{
							"name": "constant.character.escape.exper",
							"match": "\\\\."
						}
					]
				},
				{
					"name": "string.quoted.single.exper",
					"begin": "'",
					"end": "'"
				}
			]
		},

		"interpolation": {
			"patterns": [
				{
					"name": "variable.parameter.interpolation.exper",
					"match": "\\{[^}]+\\}"
				}
			]
		},

		"keywords": {
			"patterns": [
				{
					"name": "keyword.control.exper",
					"match": "\\b(if|elif|else|while|for|fn|return|break|continue|del|delete)\\b"
				}
			]
		},

		"booleans": {
			"patterns": [
				{
					"name": "constant.language.boolean.exper",
					"match": "\\b(True|False)\\b"
				}
			]
		},

		"numbers": {
			"patterns": [
				{
					"name": "constant.numeric.exper",
					"match": "\\b\\d+(\\.\\d+)?\\b"
				}
			]
		},

		"operators": {
			"patterns": [
				{
					"name": "keyword.operator.exper",
					"match": "(==|!=|<=|>=|<|>|=|\\+|\\-|\\*|\\/|%|and|or|not|in)"
				}
			]
		},

		"builtins": {
			"patterns": [
				{
					"name": "support.function.builtin.exper",
					"match": "\\b(console|sleep|int|float|str|any|all)\\b"
				}
			]
		},

		"functions": {
			"patterns": [
				{
					"name": "entity.name.function.exper",
					"match": "\\b[a-zA-Z_][a-zA-Z0-9_]*(?=\\()"
				}
			]
		},

		"properties": {
			"patterns": [
				{
					"name": "support.type.property-name.exper",
					"match": "\"[^\"]+\"(?=\\s*:)"
				}
			]
		},

		"variables": {
			"patterns": [
				{
					"name": "variable.other.exper",
					"match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
				}
			]
		}
	}
}