{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Exper",
	"scopeName": "source.exper",

	"patterns": [
		{ "include": "#comments" },
		{ "include": "#strings" },
		{ "include": "#keywords" },
		{ "include": "#constants" },
		{ "include": "#numbers" },
		{ "include": "#operators" },
		{ "include": "#builtins" },
		{ "include": "#structs" },
		{ "include": "#functions" },
		{ "include": "#properties" },
		{ "include": "#variables" }
	],

	"repository": {

		"comments": {
			"patterns": [
				{
					"name": "comment.line.double-slash.exper",
					"match": "#.*$"
				}
			]
		},

		"strings": {
			"patterns": [

				{
					"name": "string.quoted.double.exper",
					"begin": "\"",
					"end": "\"",

					"patterns": [
						{
							"name": "meta.interpolation.exper",
							"begin": "\\{",
							"end": "\\}",

							"patterns": [
								{
									"name": "variable.parameter.exper",
									"match": "[a-zA-Z_][a-zA-Z0-9_]*"
								}
							]
						}
					]
				},

				{
					"name": "string.quoted.single.exper",
					"begin": "'",
					"end": "'",

					"patterns": [
						{
							"name": "meta.interpolation.exper",
							"begin": "\\{",
							"end": "\\}",

							"patterns": [
								{
									"name": "variable.parameter.exper",
									"match": "[a-zA-Z_][a-zA-Z0-9_]*"
								}
							]
						}
					]
				}
			]
		},

		"keywords": {
			"patterns": [
				{
					"name": "keyword.control.exper",
					"match": "\\b(if|elif|else|while|for|fn|return|break|continue|del|delete|struct)\\b"
				}
			]
		},

		"constants": {
			"patterns": [
				{
					"name": "constant.language.exper",
					"match": "\\b(True|False|None)\\b"
				}
			]
		},

		"numbers": {
			"patterns": [

				{
					"name": "constant.numeric.hex.exper",
					"match": "\\b0[xX][0-9a-fA-F]+\\b"
				},

				{
					"name": "constant.numeric.binary.exper",
					"match": "\\b0[bB][01]+\\b"
				},

				{
					"name": "constant.numeric.exper",
					"match": "\\b\\d+(\\.\\d+)?\\b"
				}
			]
		},

		"operators": {
			"patterns": [
				{
					"name": "keyword.operator.exper",
					"match": "(\\+\\+|--|\\+=|-=|\\*=|/=|//=|%=|\\^=|&=|\\|=|==|!=|<=|>=|<|>|=|\\+|\\-|\\*|\\/|//|%|\\^|&|\\||~|!|and|or|not|in)"
				}
			]
		},

		"builtins": {
			"patterns": [
				{
					"name": "support.function.builtin.exper",
					"match": "\\b(console|sleep|int|float|str|any|all|bin|hex|oct)\\b"
				}
			]
		},

		"structs": {
			"patterns": [
				{
					"name": "storage.type.exper",
					"match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
				}
			]
		},

		"functions": {
			"patterns": [

				{
					"name": "entity.name.function.definition.exper",
					"match": "(?<=fn\\s)[a-zA-Z_][a-zA-Z0-9_]*"
				},

				{
					"name": "entity.name.function.exper",
					"match": "\\b[a-zA-Z_][a-zA-Z0-9_]*(?=\\()"
				}
			]
		},

		"properties": {
			"patterns": [

				{
					"name": "variable.other.property.exper",
					"match": "(?<=\\.)[a-zA-Z_][a-zA-Z0-9_]*"
				},

				{
					"name": "support.type.property-name.exper",
					"match": "\"[^\"]+\"(?=\\s*:)"
				}
			]
		},
		
		"variables": {
			"patterns": [
				{
					"name": "variable.other.readwrite.exper",
					"match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
				}
			]
		}
	}
}